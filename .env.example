# Copy to .env and fill in. .env is gitignored and must never be committed.
# cp .env.example .env

# HuggingFace write token, from https://huggingface.co/settings/tokens
# Used only by scripts/publish_hf.py to mirror the dataset and model to the Hub.
HF_TOKEN=

# OpenAI key, optional. The app and the explanation layer work fully without it
# (the deterministic template path is the default and the demo path).
OPENAI_API_KEY=
